{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sine.io/issue-workflow-kit/task-execution.schema.json",
  "title": "Issue Workflow Kit task-execution/v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion", "planId", "taskId", "issueNumber", "issueUrl", "workflowRevision",
    "approvalDigest", "attemptId", "attempt", "agent", "branch", "allowedPaths",
    "commitPolicy", "allowedSideEffects", "maxRuntimeSeconds", "maxAttempts",
    "heartbeatIntervalSeconds", "requiredChecks", "acceptance", "verification"
  ],
  "properties": {
    "schemaVersion": { "const": "task-execution/v1" },
    "planId": { "type": "string", "pattern": "^[A-Z][A-Z0-9_-]*$" },
    "taskId": { "type": "string", "pattern": "^[A-Z][A-Z0-9_-]*$" },
    "issueNumber": { "type": "integer", "minimum": 1 },
    "issueUrl": { "type": "string", "format": "uri", "minLength": 1 },
    "workflowRevision": { "type": "string", "minLength": 1 },
    "approvalDigest": { "type": "string", "pattern": "^[0-9a-fA-F]{64}$" },
    "attemptId": { "type": "string", "pattern": "^[A-Z][A-Z0-9_-]*-A[0-9]{2,}$" },
    "attempt": { "type": "integer", "minimum": 1 },
    "agent": { "type": "string", "minLength": 1 },
    "branch": { "type": "string", "pattern": "^iwf/[a-z0-9][a-z0-9._/-]*-a[0-9]+$" },
    "allowedPaths": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
      }
    },
    "commitPolicy": { "const": "required" },
    "allowedSideEffects": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "maxRuntimeSeconds": { "type": "integer", "minimum": 1 },
    "maxAttempts": { "type": "integer", "minimum": 1 },
    "heartbeatIntervalSeconds": { "type": "integer", "minimum": 1 },
    "requiredChecks": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "acceptance": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/run" }
    },
    "verification": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/run" }
    }
  },
  "$defs": {
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "description"],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Z][A-Z0-9_-]*-(?:AC|V)[0-9]{2,}$" },
        "description": { "type": "string", "minLength": 1 }
      }
    }
  }
}
