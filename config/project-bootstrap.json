{
  "$schema": "./project-bootstrap.schema.json",
  "project": {
    "title": "{{repo}} Delivery",
    "owner": "{{owner}}",
    "visibility": "PRIVATE",
    "description": "Delivery board generated from config/project-bootstrap.json.",
    "statusOptions": [
      { "name": "Backlog", "color": "GRAY", "description": "Not ready to start" },
      { "name": "Ready", "color": "BLUE", "description": "Dependencies are satisfied" },
      { "name": "In progress", "color": "YELLOW", "description": "Implementation is active" },
      { "name": "In review", "color": "PURPLE", "description": "Waiting for review or acceptance" },
      { "name": "Done", "color": "GREEN", "description": "Acceptance criteria are complete" }
    ],
    "initialStatus": "Backlog",
    "fields": [
      { "name": "Priority", "source": "priority", "options": ["P0", "P1", "P2"] },
      { "name": "Phase", "source": "phase", "options": ["1 Foundation", "2 Delivery", "3 Polish"] }
    ]
  },
  "labels": [
    { "name": "bug", "color": "D73A4A", "description": "Something is not working" },
    { "name": "enhancement", "color": "A2EEEF", "description": "New feature or request" },
    { "name": "documentation", "color": "0075CA", "description": "Documentation improvement" },
    { "name": "priority:P0", "color": "B60205", "description": "Highest priority" },
    { "name": "priority:P1", "color": "D93F0B", "description": "Important delivery work" },
    { "name": "priority:P2", "color": "FBCA04", "description": "Polish and maintenance" },
    { "name": "area:system", "color": "0E8A16", "description": "System and data" },
    { "name": "area:frontend", "color": "1D76DB", "description": "Frontend" },
    { "name": "area:backend", "color": "5319E7", "description": "Backend" },
    { "name": "epic", "color": "3E4B9E", "description": "Parent delivery issue" },
    { "name": "subtask", "color": "D4C5F9", "description": "Native sub-issue" },
    { "name": "data-quality", "color": "006B75", "description": "Data quality and provenance" },
    { "name": "tech-debt", "color": "BFDADC", "description": "Technical debt" }
  ],
  "issues": []
}
