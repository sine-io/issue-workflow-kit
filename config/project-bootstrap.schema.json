{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/project-bootstrap.schema.json",
  "title": "Issue and Project bootstrap manifest",
  "type": "object",
  "required": ["project", "labels", "issues"],
  "properties": {
    "project": {
      "type": "object",
      "required": ["title", "visibility", "statusOptions", "initialStatus", "fields"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "owner": { "type": "string" },
        "visibility": { "enum": ["PUBLIC", "PRIVATE"] },
        "description": { "type": "string" },
        "initialStatus": { "type": "string", "minLength": 1 },
        "statusOptions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "color", "description"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "color": { "enum": ["GRAY", "BLUE", "GREEN", "YELLOW", "ORANGE", "RED", "PINK", "PURPLE"] },
              "description": { "type": "string" }
            }
          }
        },
        "fields": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "source", "options"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "source": { "type": "string", "minLength": 1 },
              "options": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
            }
          }
        }
      }
    },
    "labels": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "color", "description"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "color": { "type": "string", "pattern": "^[0-9A-Fa-f]{6}$" },
          "description": { "type": "string" }
        }
      }
    },
    "issues": {
      "type": "array",
      "items": { "$ref": "#/$defs/issue" }
    }
  },
  "$defs": {
    "issue": {
      "type": "object",
      "required": ["id", "title", "priority", "phase", "area", "goal", "value", "current", "expected", "scope", "acceptance", "tests", "dependsOn"],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Z][A-Z0-9_-]*(\\.[0-9]+)?$" },
        "title": { "type": "string", "minLength": 1 },
        "priority": { "type": "string", "minLength": 1 },
        "phase": { "type": "string", "minLength": 1 },
        "area": { "type": "string", "minLength": 1 },
        "labels": { "type": "array", "items": { "type": "string" } },
        "goal": { "type": "string", "minLength": 1 },
        "value": { "type": "string", "minLength": 1 },
        "current": { "type": "string", "minLength": 1 },
        "expected": { "type": "string", "minLength": 1 },
        "scope": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "outOfScope": { "type": "array", "items": { "type": "string" } },
        "dataRequirements": { "type": "array", "items": { "type": "string" } },
        "acceptance": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "tests": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "dependsOn": { "type": "array", "items": { "type": "string" } },
        "children": { "type": "array", "items": { "$ref": "#/$defs/issue" } }
      }
    }
  }
}

